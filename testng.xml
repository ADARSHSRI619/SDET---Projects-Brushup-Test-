<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="SDET Parallel Suite" parallel="tests" thread-count="3">
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Authentication Tests" preserve-order="false">
        <classes>
            <class name="com.framework.tests.LoginTest"/>
        </classes>
    </test>

    <test name="Form Tests" preserve-order="false">
        <classes>
            <class name="com.framework.tests.FormSubmissionTest"/>
        </classes>
    </test>

    <test name="Table Validation Tests" preserve-order="false">
        <classes>
            <class name="com.framework.tests.DynamicTableTest"/>
        </classes>
    </test>
</suite>
